{
  "name": "@visual-json/ui-shared",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Shared UI utilities for visual-json framework packages.",
  "keywords": [
    "json",
    "editor",
    "tree",
    "visual"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.ts\""
  },
  "dependencies": {
    "@visual-json/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "5.9.3"
  }
}
